
class Complex(object):
    def __init__(self, real, imaginary):
        self.real = real
        self.imaginary = imaginary
        
    def __add__(self, no):
        return Complex(self.real + no.real, self.imaginary + no.imaginary)
        
    def __sub__(self, no):
        return Complex(self.real - no.real, self.imaginary - no.imaginary)
        
    def __mul__(self, no):
        real_val = self.real * no.real - self.imaginary * no.imaginary
        imag_val = self.real * no.imaginary + self.imaginary * no.real
        return Complex(real_val, imag_val)

    def __truediv__(self, no):
        denom = no.real**2 + no.imaginary**2
        real_val = (self.real * no.real + self.imaginary * no.imaginary) / denom
        imag_val = (self.imaginary * no.real - self.real * no.imaginary) / denom
        return Complex(real_val, imag_val)

    def mod(self):
        return Complex(math.sqrt(self.real**2 + self.imaginary**2), 0)

    def __str__(self):
        if self.imaginary == 0:
            return "{:.2f}+0.00i".format(self.real)
        elif self.real == 0:
            return "0.00{:+.2f}i".format(self.imaginary)
        else:
            return "{:.2f}{:+.2f}i".format(self.real, self.imaginary)

