import re

def is_valid_uid(uid):
    if len(uid) != 10:
        return False
    
    if not uid.isalnum():
        return False
    
    if len(set(uid)) != 10:
        return False
    
    if len(re.findall(r'\d', uid)) < 3:
        return False
    
    if len(re.findall(r'[A-Z]', uid)) < 2:
        return False
    
    return True

# Process test cases
for _ in range(int(input())):
    print("Valid" if is_valid_uid(input()) else "Invalid")
