/*
 * Complete the 'hourglassSum' function below.
 *
 * The function is expected to return an INTEGER.
 * The function accepts 2D_INTEGER_ARRAY arr as parameter.
 */

int hourglassSum(vector<vector<int>> arr) {
    int max_sum = numeric_limits<int>::min();

    // The grid is 6x6. An hourglass is 3x3.
    // We only need to iterate through the top-left corner of each possible hourglass.
    // The rows we can start an hourglass from are 0 to 3 (inclusive).
    // The columns we can start an hourglass from are 0 to 3 (inclusive).
    for (int i = 0; i <= 3; ++i) {
        for (int j = 0; j <= 3; ++j) {
            // Calculate the sum of the current hourglass
            int current_sum = 0;
            
            // Top row of the hourglass
            current_sum += arr[i][j] + arr[i][j + 1] + arr[i][j + 2];
            
            // Middle element of the hourglass
            current_sum += arr[i + 1][j + 1];
            
            // Bottom row of the hourglass
            current_sum += arr[i + 2][j] + arr[i + 2][j + 1] + arr[i + 2][j + 2];
            
            // Update the maximum sum if the current sum is greater
            if (current_sum > max_sum) {
                max_sum = current_sum;
            }
        }
    }
    
    return max_sum;
}

